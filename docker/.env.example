# Observability Stack Credentials
# Copy to .env and set real values before first run:
#   cp .env.example .env
#   # Edit .env with your passwords

# Phoenix PostgreSQL
PHOENIX_DB_USER=phoenix
PHOENIX_DB_PASSWORD=CHANGE_ME
PHOENIX_DB_NAME=phoenix

# Phoenix ports
PHOENIX_UI_PORT=6006
PHOENIX_OTLP_PORT=4317

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_PORT=3001
